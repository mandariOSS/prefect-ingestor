# =============================================================================
# Mandari Prefect Ingestor — Environment Configuration
# =============================================================================
# Copy to .env and adjust values

# === Datenbank ===
DATABASE_URL=postgresql+asyncpg://ingestor:ingestor_dev@localhost:5432/ingestor

# === Prefect ===
PREFECT_API_URL=http://localhost:4200/api
# Bei Self-Hosted-Server lassen, bei Cloud setzen:
# PREFECT_API_KEY=...

# === API ===
API_HOST=0.0.0.0
API_PORT=8080
# Eingehende Management-API-Requests authentifizieren
API_KEY=change-me-to-a-strong-key

# === OParl-Sync-Settings ===
SYNC_INTERVAL_MINUTES=10
FULL_SYNC_HOUR=3
HTTP_TIMEOUT_SECONDS=60
HTTP_MAX_RETRIES=3
HTTP_USER_AGENT=Mandari-Ingestor/0.1

# === Text-Extraktion ===
TEXT_EXTRACTION_ENABLED=true
TEXT_EXTRACTION_MAX_SIZE_MB=50
TEXT_EXTRACTION_CONCURRENCY=3

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json   # oder "console" für menschenlesbar

# === CORS (für Mandari-Anbindung) ===
CORS_ORIGINS=https://mandari.de,https://dev.mandari.de,http://localhost:8000
