# =============================================================================
# Mandari Prefect Ingestor — Environment Configuration
# =============================================================================
# Copy to .env and adjust values

# === Datenbank ===
DATABASE_URL=postgresql+asyncpg://ingestor:ingestor_dev@localhost:5432/ingestor

# === Prefect ===
# Leer lassen für Embedded-Betrieb (unsere Scheduler/OCR-Worker brauchen keinen Server).
PREFECT_API_URL=
# PREFECT_API_KEY=...   # Nur bei Prefect Cloud

# === API ===
API_HOST=0.0.0.0
API_PORT=9080
# Bootstrap-API-Key: greift NUR solange keine api_keys in der DB existieren.
# In Produktion via POST /api/admin/api-keys echten Admin-Key anlegen.
API_KEY=change-me-to-a-strong-key
# DEV_MODE=true erlaubt Default-Key "change-me" für lokale Entwicklung.
# In Produktion IMMER auf false lassen (oder weglassen).
DEV_MODE=false

# === CORS für /api/admin (strikt, credentialed) ===
# /api/oparl bleibt offen (OParl-Spec verlangt *), das hier betrifft nur Admin.
ADMIN_CORS_ORIGINS=http://localhost:8000,https://mandari.de

# === Rate-Limiting ===
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH_FAILURE=5/minute

# === OParl-Sync-Settings ===
SYNC_INTERVAL_MINUTES=10
FULL_SYNC_HOUR=3
HTTP_TIMEOUT_SECONDS=60
HTTP_MAX_RETRIES=3
HTTP_USER_AGENT=Mandari-Ingestor/0.1

# Maximale parallele Bodies pro Sync-Zyklus (begrenzt DB- und HTTP-Last)
SYNC_BODY_CONCURRENCY=4
# Nach N aufeinander folgenden Fehlschlägen wird die Quelle automatisch
# in Quarantäne gesetzt (is_active=false, quarantined_at=now)
SYNC_QUARANTINE_THRESHOLD=10
# Timeout pro Source-Sync (verhindert "stuck syncs")
SYNC_SOURCE_TIMEOUT_SECONDS=1800

# === Auto-Enrichment nach Body-Sync ===
ENRICHMENT_AUTO_PHOTOS=true
# Geocoding nur wenn NOMINATIM_URL konfiguriert
ENRICHMENT_AUTO_GEOCODING=false

# === OCR-Worker ===
OCR_ENABLED=true
OCR_BATCH_SIZE=30
OCR_CONCURRENCY=3
OCR_MAX_FILE_SIZE_MB=50

# === KI-API OCR (Stufe 3 Fallback, optional) ===
# Jede OpenAI-kompatible API. Ohne Key: nur pypdf + Tesseract (kostenlos).
# OCR_AI_API_KEY=sk-...
# OCR_AI_BASE_URL=https://api.mistral.ai/v1
# OCR_AI_MODEL=mistral-ocr-latest
#
# Beispiele:
#   Mistral:  OCR_AI_BASE_URL=https://api.mistral.ai/v1       OCR_AI_MODEL=mistral-ocr-latest
#   OpenAI:   OCR_AI_BASE_URL=https://api.openai.com/v1        OCR_AI_MODEL=gpt-4o
#   Deepseek: OCR_AI_BASE_URL=https://api.deepseek.com         OCR_AI_MODEL=deepseek-chat
#   Groq:     OCR_AI_BASE_URL=https://api.groq.com/openai/v1   OCR_AI_MODEL=llama-3.3-70b-versatile
#   Ollama:   OCR_AI_BASE_URL=http://localhost:11434/v1         OCR_AI_MODEL=llama3.2-vision

# === Geocoding (optional) ===
# Leer lassen um Geocoding zu deaktivieren. Sonst URL einer Nominatim-Instanz.
NOMINATIM_URL=

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=console   # oder "json" für strukturiertes Logging

# === Bcrypt-Rounds (Test-Override) ===
# Nur in Tests auf 4 setzen für Speed. Produktiv NICHT setzen (Default: 12).
# BCRYPT_ROUNDS=4

# === Legacy / OParl-Public-CORS ===
# /api/oparl bedient alle Origins mit *; diese Variable wird aktuell nicht mehr
# aktiv genutzt, bleibt für Rückwärtskompatibilität.
CORS_ORIGINS=*
